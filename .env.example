# =============================================================================
# MeshAnythingV2 API — Machine-specific configuration
#
# Usage:
#   cp .env.example .env
#   vim .env              # fill in paths for THIS machine
#   docker compose up -d
#
# .env is gitignored — never commit it.
# =============================================================================

# -- HuggingFace model cache (host path) --------------------------------------
# Model (~1.5 GB) is downloaded on first request and cached here.
# Examples:
#   /pegaai/model_team/huggingface_cache   (prod server)
#   ./hf_cache                             (dev workstation, relative to project)
HF_CACHE_PATH=./hf_cache

# -- CUDA arch list ------------------------------------------------------------
# "12.0" = RTX Pro 6000 only (faster build).
# Full list for multi-GPU compatibility:
# TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9;9.0;10.0;12.0
TORCH_CUDA_ARCH_LIST=12.0

# -- Build parallelism ---------------------------------------------------------
MAX_JOBS=4

# -- Corporate proxy (set to empty if not needed) ------------------------------
HTTP_PROXY=
HTTPS_PROXY=

# -- Output directory (persistent storage for generated meshes) ----------------
MESHANYTHING_OUTPUT_PATH=./outputs

# -- GPU assignment ------------------------------------------------------------
# Run `nvidia-smi` on the host to see available devices.
GPU_ID=0

# -- Port mapping --------------------------------------------------------------
MESHANYTHING_PORT=8192

# -- Optional: HuggingFace token (for gated model repos) ----------------------
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
